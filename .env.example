# ==================================================
# ⚙️ REQUIRED ENVIRONMENT VARIABLES
# ==================================================

# 🚀 Application Mode
MODE="DEV"  # DEV, TEST, or PROD

# ==================================================
# 🗄️ Database (PostgreSQL)
# ==================================================
DB_USER="postgres"
DB_PASS="postgres"
DB_HOST="backend_db"     # Use 'backend_db' for Docker
DB_PORT="5432"
DB_NAME="postgres_db"

# ==================================================
# ⚡ Redis (Cache)
# ==================================================
REDIS_HOST="cache"  # Use 'cache' for Docker
REDIS_PORT="6379"

# ==================================================
# 🤖 Telegram Bot
# ==================================================
# Get token from @BotFather
TELEGRAM_TOKEN="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz"