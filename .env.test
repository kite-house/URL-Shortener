# ==================================================
# ⚙️ REQUIRED ENVIRONMENT VARIABLES
# ==================================================

# 🚀 Application Mode
MODE = "TEST"  # DEV, TEST, or PROD
BACKEND_PORT = "8000"
BACKEND_HOST = "0.0.0.0"
FRONTEND_PORT = "80"

# ==================================================
# 🗄️ Database (PostgreSQL)
# ==================================================
DB_USER = "test_postgres"
DB_PASS = "test_postgres"
DB_HOST = "test_postgres_db"    # Use 'postgres_db' for Docker
DB_PORT = "5432"
DB_NAME = "test_postgres_db"
DATABASE_URL= "postgresql://test_user:test_pass@test_db:5432/test_db"

# ==================================================
# ⚡ Redis (Cache)
# ==================================================
REDIS_HOST = "test_cache"  # Use 'cache' for Docker
REDIS_PORT = "6379"
REDIS_PASSWORD = "1234"
REDIS_URL = "redis://test_cache:6379"